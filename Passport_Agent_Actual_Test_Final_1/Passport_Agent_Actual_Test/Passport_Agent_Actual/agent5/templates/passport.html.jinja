<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PathCredits Passport — {{ student_name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #F7F8FC;
    --card:      #FFFFFF;
    --card-alt:  #F0F3FA;
    --border:    #E2E6F0;
    --text:      #1A1D2E;
    --muted:     #6B7394;
    --muted2:    #9BA3C2;

    --ec:  #3B72F2;
    --gc:  #12B47A;
    --rff: #8B5CF6;
    --cr:  #F27C1E;
    --ct:  #D4A017;
    --ci:  #E05252;

    --ec-tint:  #EBF1FE;
    --gc-tint:  #E6F9F2;
    --rff-tint: #F3EFFE;
    --cr-tint:  #FEF3E8;
    --ct-tint:  #FDF6E3;
    --ci-tint:  #FEEEEE;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-weight: 300;
    line-height: 1.55;
    padding: 36px 20px 60px;
  }

  .page { max-width: 900px; margin: 0 auto; }

  /* ── HEADER ── */
  .header {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 28px;
    padding: 24px 28px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3B72F2 0%, #8B5CF6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Fraunces', serif;
    font-size: 24px;
    font-weight: 400;
    color: #fff;
    flex-shrink: 0;
    letter-spacing: 1px;
  }

  .header-info { flex: 1; min-width: 0; }

  .header-name {
    font-family: 'Fraunces', serif;
    font-size: 26px;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .header-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--card-alt);
    border: 1px solid var(--border);
    font-size: 11.5px;
    font-weight: 500;
    color: var(--muted);
    white-space: nowrap;
  }

  .brand-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--muted2);
    padding-top: 2px;
  }

  /* ── GRID ── */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  /* ── CARD ── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 14px;
  }

  .card-label {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.2;
  }

  .card-score {
    font-family: 'Fraunces', serif;
    font-size: 28px;
    font-weight: 400;
    line-height: 1;
    flex-shrink: 0;
  }

  .card-score sub {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: var(--muted2);
    vertical-align: baseline;
    margin-left: 1px;
  }

  .c-ec  { color: var(--ec); }
  .c-gc  { color: var(--gc); }
  .c-rff { color: var(--rff); }
  .c-cr  { color: var(--cr); }
  .c-ct  { color: var(--ct); }
  .c-ci  { color: var(--ci); }

  /* ── SUB-ROWS ── */
  .sub-row {
    display: grid;
    grid-template-columns: 110px 1fr 38px;
    align-items: center;
    gap: 8px;
    margin-bottom: 7px;
  }

  .sub-label {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-track {
    height: 4px;
    background: var(--card-alt);
    border-radius: 99px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.3s ease;
  }

  .bg-ec  { background: var(--ec); }
  .bg-gc  { background: var(--gc); }
  .bg-rff { background: var(--rff); }
  .bg-cr  { background: var(--cr); }
  .bg-ct  { background: var(--ct); }
  .bg-ci  { background: var(--ci); }

  .sub-val {
    font-size: 11px;
    font-weight: 600;
    color: var(--text);
    text-align: right;
  }

  /* ── NARRATIVE BLOCK (CT / CI) ── */
  .narrative-block {
    font-size: 12.5px;
    font-weight: 300;
    color: var(--text);
    line-height: 1.6;
    margin-bottom: 10px;
    padding: 10px 12px;
    background: var(--card-alt);
    border-radius: 8px;
  }

  /* ── REASONING ── */
  .reasoning {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .reasoning-label {
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--muted2);
  }

  .reasoning-text {
    font-size: 12px;
    font-weight: 400;
    color: var(--text);
    line-height: 1.6;
  }

  .evidence-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 2px;
  }

  .chip {
    display: inline-block;
    padding: 2px 9px;
    border-radius: 20px;
    font-size: 10.5px;
    font-weight: 500;
    border: 1px solid currentColor;
  }

  .bc-ec  { color: var(--ec);  background: var(--ec-tint); }
  .bc-gc  { color: var(--gc);  background: var(--gc-tint); }
  .bc-rff { color: var(--rff); background: var(--rff-tint); }
  .bc-cr  { color: var(--cr);  background: var(--cr-tint); }
  .bc-ct  { color: var(--ct);  background: var(--ct-tint); }
  .bc-ci  { color: var(--ci);  background: var(--ci-tint); }

  /* ── SIGNAL BADGE ── */
  .signal-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.5px;
    align-self: flex-start;
  }

  .signal-positive     { background: #E6F9F2; color: #12B47A; }
  .signal-mixed        { background: #FDF6E3; color: #D4A017; }
  .signal-early_stage  { background: #F0F3FA; color: #6B7394; }
  .signal-developing   { background: #F0F3FA; color: #6B7394; }
  .signal-highly_focused { background: #EBF1FE; color: #3B72F2; }
  .signal-emerging     { background: #F3EFFE; color: #8B5CF6; }
  .signal-exploratory  { background: #F0F3FA; color: #6B7394; }

  /* ── SOURCE BADGE ── */
  .source-badge {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 20px;
    font-size: 9.5px;
    font-weight: 500;
    background: var(--card-alt);
    color: var(--muted2);
    border: 1px solid var(--border);
    margin-left: 6px;
    vertical-align: middle;
  }

  /* ── FOOTER ── */
  .footer {
    margin-top: 32px;
    text-align: center;
    font-size: 11px;
    color: var(--muted2);
    font-weight: 400;
    line-height: 1.7;
  }

  .footer strong { font-weight: 600; color: var(--muted); }

  .overall-block {
    text-align: right;
    flex-shrink: 0;
    padding-left: 16px;
  }
  .overall-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--muted2);
    margin-bottom: 2px;
  }
  .overall-num {
    font-family: "Fraunces", serif;
    font-size: 44px;
    font-weight: 400;
    line-height: 1;
    color: var(--text);
  }
  .overall-denom {
    font-size: 16px;
    color: var(--muted2);
    font-family: "Inter", sans-serif;
    font-weight: 300;
  }
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="header">
    <div class="avatar">{{ initials }}</div>
    <div class="header-info">
      <div class="brand-tag">PathCredits Passport &middot; SPEAKHIRE</div>
      <h1 class="header-name">{{ student_name }}</h1>
      <div class="header-pills">
        <span class="pill">{{ email }}</span>
        <span class="pill">SPEAKHIRE Foundational Year</span>
      </div>
    </div>
    <div class="overall-block">
      <div class="overall-label">OVERALL</div>
      <div class="overall-num">{{ overall }}<span class="overall-denom">/100</span></div>
    </div>
  </div>

  <!-- CARD GRID -->
  <div class="grid">
    {% for pillar in pillars %}
    <div class="card">
      <div class="card-top">
        <div class="card-label">{{ pillar.label | upper }}</div>
        <div class="card-score c-{{ pillar.key | lower }}">
          {{ pillar.score }}<sub>/100</sub>
        </div>
      </div>

      {% if pillar.sub_items %}
        {% for sub in pillar.sub_items %}
        <div class="sub-row">
          <div class="sub-label">{{ sub.label }}</div>
          <div class="bar-track">
            <div class="bar-fill bg-{{ pillar.key | lower }}" style="width:{{ sub.width }}%"></div>
          </div>
          <div class="sub-val">{{ sub.value }}</div>
        </div>
        {% endfor %}
      {% else %}
        <!-- CT / CI: single score bar -->
        <div class="sub-row">
          <div class="sub-label">Score</div>
          <div class="bar-track">
            <div class="bar-fill bg-{{ pillar.key | lower }}"
                 style="width:{{ pillar.score }}%"></div>
          </div>
          <div class="sub-val">{{ pillar.score }}</div>
        </div>
      {% endif %}

      <div class="reasoning">
        <div class="reasoning-label">Profile Note</div>
        <div class="reasoning-text">{{ pillar.narrative }}</div>
        {% if pillar.evidence_chips %}
        <div class="evidence-chips">
          {% for chip in pillar.evidence_chips %}
          <span class="chip bc-{{ pillar.key | lower }}">{{ chip }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- FOOTER -->
  <div class="footer">
    PathCredits Passport &middot; SPEAKHIRE &middot; {{ email }}
  </div>

</div>
</body>
</html>
